{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "workspace.checkThirdParty": "Ask",
  "workspace.userThirdParty": [
    "/home/linden/dev/lua-addons"
  ],
  "runtime.nonstandardSymbol": [
    "/**/",
    "`",
    "+=",
    "-=",
    "*=",
    "/=",
    "<<=",
    ">>=",
    "&=",
    "|=",
    "^="
  ],
  "diagnostics.disable": [
    "unbalanced-assignments",
    "lowercase-global"
  ],
  "workspace.ignoreDir": [
    ".vscode",
    ".git",
    ".github",
    "node_modules",
    "web"
  ],
  "workspace.library": [
    "../ox_lib",
    "/home/linden/dev/lua-addons/fivem-lls-addon/library"
  ],
  "runtime.special": {
    "lib.load": "require"
  },
  "runtime.pathStrict": true,
  "runtime.plugin": "/home/linden/dev/lua-addons/fivem-lls-addon/plugin.lua"
}
